{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "message_id": {
            "type": "string"
        },
        "trip_id": {
            "type": "string"
        },
        "author": {
            "type": "object",
            "properties": {
                "user_id": {
                    "type": "string"
                },
                "member_id": {
                    "type": "string"
                }
            },
            "required": [
                "user_id",
                "member_id"
            ]
        },
        "thread": {
            "type": "object",
            "properties": {
                "thread_id": {
                    "type": "string"
                },
                "parent_id": {
                    "type": "null"
                },
                "reply_count": {
                    "type": "integer"
                }
            },
            "required": [
                "thread_id",
                "parent_id",
                "reply_count"
            ]
        },
        "context": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string"
                },
                "entity_id": {
                    "type": "string"
                }
            },
            "required": [
                "type",
                "entity_id"
            ]
        },
        "content": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string"
                },
                "mentions": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        }
                    ]
                },
                "attachments": {
                    "type": "array",
                    "items": {}
                }
            },
            "required": [
                "text",
                "mentions",
                "attachments"
            ]
        },
        "reactions": {
            "type": "array",
            "items": [
                {
                    "type": "object",
                    "properties": {
                        "emoji": {
                            "type": "string"
                        },
                        "user_ids": {
                            "type": "array",
                            "items": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "count": {
                            "type": "integer"
                        }
                    },
                    "required": [
                        "emoji",
                        "user_ids",
                        "count"
                    ]
                },
                {
                    "type": "object",
                    "properties": {
                        "emoji": {
                            "type": "string"
                        },
                        "user_ids": {
                            "type": "array",
                            "items": [
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "count": {
                            "type": "integer"
                        }
                    },
                    "required": [
                        "emoji",
                        "user_ids",
                        "count"
                    ]
                }
            ]
        },
        "flags": {
            "type": "object",
            "properties": {
                "is_pinned": {
                    "type": "boolean"
                },
                "is_decision": {
                    "type": "boolean"
                },
                "is_edited": {
                    "type": "boolean"
                },
                "is_deleted": {
                    "type": "boolean"
                }
            },
            "required": [
                "is_pinned",
                "is_decision",
                "is_edited",
                "is_deleted"
            ]
        },
        "meta": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "edited_at": {
                    "type": "null"
                },
                "deleted_at": {
                    "type": "null"
                }
            },
            "required": [
                "created_at",
                "edited_at",
                "deleted_at"
            ]
        }
    },
    "required": [
        "message_id",
        "trip_id",
        "author",
        "thread",
        "context",
        "content",
        "reactions",
        "flags",
        "meta"
    ]
}