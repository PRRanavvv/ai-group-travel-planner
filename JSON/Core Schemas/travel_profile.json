{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "travel_profile_id": {
            "type": "string"
        },
        "user_id": {
            "type": "string"
        },
        "travel_style": {
            "type": "object",
            "properties": {
                "pace": {
                    "type": "string"
                },
                "accommodation": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "transport": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "group_style": {
                    "type": "string"
                }
            },
            "required": [
                "pace",
                "accommodation",
                "transport",
                "group_style"
            ]
        },
        "interests": {
            "type": "object",
            "properties": {
                "primary": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "secondary": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "excluded": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        }
                    ]
                }
            },
            "required": [
                "primary",
                "secondary",
                "excluded"
            ]
        },
        "food": {
            "type": "object",
            "properties": {
                "cuisines_preferred": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "dietary_restrictions": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        }
                    ]
                },
                "meal_budget_tier": {
                    "type": "string"
                },
                "adventurousness": {
                    "type": "integer"
                }
            },
            "required": [
                "cuisines_preferred",
                "dietary_restrictions",
                "meal_budget_tier",
                "adventurousness"
            ]
        },
        "budget": {
            "type": "object",
            "properties": {
                "currency": {
                    "type": "string"
                },
                "range": {
                    "type": "object",
                    "properties": {
                        "min": {
                            "type": "integer"
                        },
                        "max": {
                            "type": "integer"
                        }
                    },
                    "required": [
                        "min",
                        "max"
                    ]
                },
                "per": {
                    "type": "string"
                },
                "flexibility": {
                    "type": "string"
                }
            },
            "required": [
                "currency",
                "range",
                "per",
                "flexibility"
            ]
        },
        "constraints": {
            "type": "object",
            "properties": {
                "dislikes": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "accessibility_needs": {
                    "type": "array",
                    "items": {}
                },
                "avoid_countries": {
                    "type": "array",
                    "items": {}
                },
                "max_flight_hrs": {
                    "type": "integer"
                },
                "requires_wifi": {
                    "type": "boolean"
                }
            },
            "required": [
                "dislikes",
                "accessibility_needs",
                "avoid_countries",
                "max_flight_hrs",
                "requires_wifi"
            ]
        },
        "trip_goals": {
            "type": "array",
            "items": [
                {
                    "type": "string"
                },
                {
                    "type": "string"
                }
            ]
        },
        "meta": {
            "type": "object",
            "properties": {
                "completeness_score": {
                    "type": "number"
                },
                "trips_completed": {
                    "type": "integer"
                },
                "last_trip_at": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            },
            "required": [
                "completeness_score",
                "trips_completed",
                "last_trip_at",
                "updated_at"
            ]
        }
    },
    "required": [
        "travel_profile_id",
        "user_id",
        "travel_style",
        "interests",
        "food",
        "budget",
        "constraints",
        "trip_goals",
        "meta"
    ]
