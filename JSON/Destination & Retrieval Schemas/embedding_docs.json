                {
                    "type": "object",
                    "properties": {
                        "chunk_id": {
                            "type": "string"
                        },
                        "text": {
                            "type": "string"
                        },
                        "char_count": {
                            "type": "integer"
                        },
                        "token_count": {
                            "type": "integer"
                        },
                        "chunk_index": {
                            "type": "integer"
                        },
                        "overlap_tokens": {
                            "type": "integer"
                        }
                    },
                    "required": [
                        "chunk_id",
                        "text",
                        "char_count",
                        "token_count",
                        "chunk_index",
                        "overlap_tokens"
