                        },
                        "rank": {
                            "type": "integer"
                        },
                        "score": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "entity_id",
                        "type",
                        "rank",
                        "score"
                    ]
                },
                {
                    "type": "object",
                    "properties": {
                        "entity_id": {
                            "type": "string"
                        },
                        "type": {
                            "type": "string"
                        },
                        "rank": {
                            "type": "integer"
                        },
                        "score": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "entity_id",
                        "type",
                        "rank",
                        "score"
                    ]
                },
                {
                    "type": "object",
                    "properties": {
                        "entity_id": {
                            "type": "string"
                        },
                        "type": {
                            "type": "string"
                        },
                        "rank": {
                            "type": "integer"
                        },
                        "score": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "entity_id",
                        "type",
                        "rank",
                        "score"
                    ]
                },
                {
                    "type": "object",
                    "properties": {
                        "entity_id": {
                            "type": "string"
                        },
                        "type": {
                            "type": "string"
                        },
                        "rank": {
                            "type": "integer"
                        },
                        "score": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "entity_id",
                        "type",
                        "rank",
                        "score"
                    ]
                }
            ]
        },
        "factors": {
            "type": "object",
            "properties": {
                "weights_version": {
                    "type": "string"
                },
                "applied_weights": {
                    "type": "object",
                    "properties": {
                        "group_fit": {
                            "type": "number"
                        },
                        "budget_fit": {
                            "type": "number"
                        },
                        "popularity": {
                            "type": "number"
                        },
                        "uniqueness": {
                            "type": "number"
                        },
                        "timing_fit": {
